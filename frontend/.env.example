# ASHA AI Frontend Environment Variables

# Backend API URL
VITE_API_URL=http://localhost:8010/api/v1

# App Name
VITE_APP_NAME="ASHA AI"

# Voice agent uses backend OpenAI endpoints — no frontend API key needed

# ---------------------------------------------------------------------------
# Auth — Supabase (recommended)
# Set VITE_AUTH_BYPASS=true only for local demo without Supabase
# ---------------------------------------------------------------------------
VITE_AUTH_BYPASS=false

# Supabase — Dashboard → Project Settings → API → Project URL + anon public key
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key
