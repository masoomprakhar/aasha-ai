# ---------------------------------------------------------------------------
# Database — Supabase Postgres (recommended)
# Dashboard → Project Settings → Database → Connection string → URI
# Use Transaction pooler, port 6543, for async apps
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL_SYNC=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Local Postgres (alternative — comment out Supabase URLs above if using this)
# DATABASE_URL=postgresql+asyncpg://USER@localhost:5432/asha_ai
# DATABASE_URL_SYNC=postgresql://USER@localhost:5432/asha_ai

# ---------------------------------------------------------------------------
# Supabase — required for POST /api/v1/auth/supabase (JWT exchange)
# Dashboard → Project Settings → API
# ---------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_public_key

# Optional — admin API (not required for email/password signup via the frontend)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional — verify JWTs locally instead of calling Supabase /auth/v1/user
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# Backend API JWT (issued after Supabase session exchange)
JWT_SECRET=your-super-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI API — voice agent (chat, STT, TTS)
OPENAI_API_KEY=your_openai_api_key
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova
OPENAI_STT_MODEL=whisper-1

# Gemini API (fallback when OPENAI_API_KEY is not set)
GEMINI_API_URL=http://your-gemini-api-host/generate

# Local Whisper fallback (when OPENAI_API_KEY is not set)
WHISPER_MODEL=base

# App Settings
DEBUG=true
CORS_ORIGINS=http://localhost:5180,http://127.0.0.1:5180
